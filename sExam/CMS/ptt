document.addEventListener("DOMContentLoaded", () => {


    // ── 드롭다운 열기 / 닫기 ──
    const sortWrap = document.querySelector('.searchSort_select');
    const optSortBtn = document.getElementById('optSort');
    const sortSpan = optSortBtn.querySelector('span');

    optSortBtn.addEventListener('click', function () {
        const isOpen = sortWrap.classList.toggle('open');
        // 접근성: aria-expanded 동기화
        optSortBtn.setAttribute('aria-expanded', isOpen);
    });

    // 외부 클릭 시 닫기
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.searchSort_select')) {
            sortWrap.classList.remove('open');
            optSortBtn.setAttribute('aria-expanded', 'false');
        }
    });

    // ── 정렬 옵션 클릭 ──
    document.querySelectorAll('#selBoxSchOrderby .link_comm').forEach(function (link) {
        link.addEventListener('click', function (e) {
            e.preventDefault();

            const order = this.dataset.order;
            const label = this.textContent;

            // 버튼 텍스트 변경
            sortSpan.textContent = label;

            // on 클래스 이동
            document.querySelectorAll('#selBoxSchOrderby .link_comm').forEach(el => el.classList.remove('on'));
            this.classList.add('on');

            // 드롭다운 닫기
            sortWrap.classList.remove('open');
            optSortBtn.setAttribute('aria-expanded', 'false');
            


            // 정렬 실행
            renderCateArticles("all", order);
        });
    });




