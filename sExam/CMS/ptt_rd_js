async function fetchData(url) {

    try {
        const response = await fetch(url);
        const json = await response.json();
        return json;
    }
    catch (error) {
        console.log(error);
        loading_stop();
    }
}

function scrollUp() {
    var $hdHeight = $(".M00_A").innerHeight();

    if (!$(".empty_box").length) return;

    var emptyTop = $(".empty_box").length ? $(".empty_box").offset().top : 0;

    $('html, body').animate({
        scrollTop: emptyTop - $hdHeight
    }, 250);
    return false;
}



function renderCateArticles(type = "check", order = "desc") {

    var $errCont = $("#searchList_error");
    if ($errCont.length)
        $errCont.hide();

    if (type == "search") {
        listPointer = 0;
        curMoreCnt = 1;
        moreEnd = false;
        if (artList.length > moreStep)
            // $(".btn_more").css('visibility', 'visible');
            btnMore.style.visibility = "visible";
        //   document.querySelector('.txt_l').textContent =(lang =="ko")? '검색결과': 'Results';

    } else if (type == "check") {
        $("#notice_keyword").val(""); //검색 해제
        $('.result').html("");
        //클릭된 카테고리에 해당하는 게시글만 렌더링
        if (selectedFieldList.legnth == 0) {

            artList = allData;

        } else {
            listInit();

            var tmpArtList = allData;

            if (selectedFieldList.length) {
                $.each(selectedFieldList, function (i, obj) {


                    const MAIN_CATEGORIES = ["AI", "cloud", "보안", "CX"];
                    if (obj === "기타") {
                        let filteredArr = _.filter(tmpArtList, function (data) {
                            return !MAIN_CATEGORIES.some(category =>
                                data.field.includes(category)
                            );
                        });
                        $.each(filteredArr, function (j, data) {
                            artList.push(data);
                        });
                    } else {
                        let filteredArr = _.filter(tmpArtList, data => data.field.includes(obj));
                        $.each(filteredArr, function (j, data) {
                            artList.push(data);
                        });
                    }

                })
            } else {
                artList = tmpArtList;
            }

            artList = _.uniqBy(artList, 'id')
            artList = _.orderBy(artList, ['order'], ['asc']);
        }

    } else { //모든 아티클 렌더링
        listInit();
        artList = allData;
    }

    const sorted = [...artList].sort((a, b) => {
        const dateA = parseDate(a.regist_date);
        const dateB = parseDate(b.regist_date);
        return order === 'asc' ? dateA - dateB : dateB - dateA;
    });

    if (sorted.length > 0) {
        document.getElementsByClassName('filter_content')[0].innerHTML = getArtListHtml(sorted, listPointer, moreStep);
    } else {
        noResultRender();
    }



    //scrollToNext();

    //  if(curMoreCnt==1){
    //  scrollUp();
    //   }

}


