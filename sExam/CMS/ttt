<div class="container">
  <h2>특허 리스트</h2>

  <div class="searchSort_select event_select">
    <strong class="blind">검색 정렬 기준</strong>
    <div class="select_box">
      <button type="button" id="optSort" class="select_btn"
              data-option="option_recent"
              role="combobox"
              aria-controls="selBoxSchOrderby"
              aria-haspopup="listbox"
              aria-expanded="false">
        <span>최신순</span>
      </button>
      <ul id="selBoxSchOrderby" class="list" role="listbox" aria-labelledby="optSort">
        <li role="option">
          <a href="javascript:;" id="option_title" data-order="desc" class="link_comm on" role="button">등록일 최신순</a>
        </li>
        <li role="option">
          <a href="javascript:;" id="option_recent" data-order="asc" class="link_comm" role="button">등록일 오래된순</a>
        </li>
      </ul>
    </div>
  </div>

  <ul class="patent-list" id="patent-list"></ul>
</div>

<script>
  const patentData = [
    {
      "id": "1294610",
      "field": "보안",
      "title": "양자내성보안채널 구성방법 (PQC-TLS over WebSocket)",
      "link": "/kr/patents/1294610_12144.html",
      "writer": "김승영, 원성훈, 엄인섭, 이원용",
      "regist_date": "20251230-125000",
      "registnumber": "P23-22772-US01"
    },
    {
      "id": "1294609",
      "field": "물류자동화",
      "title": "순환형 축을 이용한 원통형 자재 입출고 장치 및 보관 자동 시스템",
      "link": "/kr/patents/1294609_12144.html",
      "writer": "김승영, 원성훈, 엄인섭, 이원용",
      "regist_date": "20250812-104000",
      "registnumber": "P21-22405-US02"
    },
    {
      "id": "1294562",
      "field": "AI",
      "title": "사용 중인 서비스 데이터 기반 강화학습 모델 학습 방법 및 장치",
      "link": "/kr/patents/1294562_12144.html",
      "writer": "홍길동, 김연구, 이개발 외 2인",
      "regist_date": "20250702-104000",
      "registnumber": "US 12,198,019"
    }
  ];

  // "20251230-125000" → 숫자 변환 (정렬용)
  function parseDate(dateStr) {
    return parseInt(dateStr.replace("-", ""));
  }

  // "20251230-125000" → "2025.12.30" (화면 표시용)
  function formatDate(dateStr) {
    const datePart = dateStr.split("-")[0];
    return `${datePart.slice(0, 4)}.${datePart.slice(4, 6)}.${datePart.slice(6, 8)}`;
  }

  // ── 리스트 렌더링 ──
  function renderList(order) {
    const sorted = [...patentData].sort((a, b) => {
      const dateA = parseDate(a.regist_date);
      const dateB = parseDate(b.regist_date);
      return order === 'asc' ? dateA - dateB : dateB - dateA;
    });

    const listEl = document.getElementById('patent-list');

    if (sorted.length === 0) {
      listEl.innerHTML = '<p class="empty-msg">검색 결과가 없습니다.</p>';
      return;
    }

    listEl.innerHTML = sorted.map(item => `
      <li class="patent-item">
        <div class="patent-top">
          <span class="patent-field">${item.field}</span>
          <span class="patent-date">📅 ${formatDate(item.regist_date)}</span>
