        }
    ];

    // "20251230-125000" → 비교 가능한 숫자로 변환
    function parseDate(dateStr) {
        return parseInt(dateStr.replace("-", ""));
    }

    function formatDate(dateStr) {
        // "20251230-125000" → "2025.12.30"
        const datePart = dateStr.split("-")[0];
        return `${datePart.slice(0,4)}.${datePart.slice(4,6)}.${datePart.slice(6,8)}`;
    }

    function renderList(order = 'asc') {
        // 버튼 활성화 상태 변경
        document.getElementById('btn-asc').classList.toggle('active', order === 'asc');
        document.getElementById('btn-desc').classList.toggle('active', order === 'desc');

        // 정렬
        const sorted = [...patentData].sort((a, b) => {
            const dateA = parseDate(a.regist_date);
            const dateB = parseDate(b.regist_date);
            return order === 'asc' ? dateA - dateB : dateB - dateA;
        });

        // 렌더링
        const listEl = document.getElementById('patent-list');
        listEl.innerHTML = sorted.map(item => `
            <li class="patent-item">
                <span class="patent-field">${item.field}</span>
                <div class="patent-title">
                    <a href="${item.link}">${item.title}</a>
                </div>
                <div class="patent-meta">
                    📅 ${formatDate(item.regist_date)} &nbsp;|&nbsp;
                    ✍️ ${item.writer} &nbsp;|&nbsp;
                    📋 ${item.registnumber}
                </div>
            </li>
        `).join('');
    }

    // 초기 렌더링
    renderList('asc');
</script>

