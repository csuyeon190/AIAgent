import ftplib
import os

# 설정
FTP_HOST = "서버주소"
FTP_USER = "아이디"
FTP_PASS = "비밀번호"
REMOTE_DIR = "/서버경로"
LOCAL_DIR = r"C:\다운로드폴더"

def download_all(ftp, remote_dir, local_dir):
    os.makedirs(local_dir, exist_ok=True)
    ftp.cwd(remote_dir)
    
    items = []
    ftp.retrlines("LIST", items.append)
    
    for item in items:
        parts = item.split()
        filename = parts[-1]
        local_path = os.path.join(local_dir, filename)
        
        # 대소문자 충돌 체크
        existing = [f.lower() for f in os.listdir(local_dir)]
        if filename.lower() in existing and filename not in os.listdir(local_dir):
            # 충돌 시 _upper 붙여서 저장
            name, ext = os.path.splitext(filename)
            local_path = os.path.join(local_dir, f"{name}_upper{ext}")
        
        # 파일 다운로드
        if item.startswith("-"):  # 파일인 경우
            with open(local_path, "wb") as f:
                ftp.retrbinary(f"RETR {filename}", f.write)
            print(f"Downloaded: {filename} → {os.path.basename(local_path)}")

ftp = ftplib.FTP(FTP_HOST)
ftp.login(FTP_USER, FTP_PASS)
download_all(ftp, REMOTE_DIR, LOCAL_DIR)
ftp.quit()
print("완료!")
